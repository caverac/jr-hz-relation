TEX      = pdflatex
BIB      = bibtex
MAIN     = ms
UV       = uv

FIGURES  = form-factor.pdf provenance-bias.pdf form-factor-validation.pdf resonance-overlap.pdf trapped-weight.pdf trapping-cap.pdf crossover-bias.pdf finite-thickness.pdf balescu-lenard.pdf

.PHONY: all clean distclean figures submission test-particle

all: figures $(MAIN).pdf

$(MAIN).pdf: $(MAIN).tex $(MAIN).bib $(FIGURES)
	$(TEX) $(MAIN)
	$(BIB) $(MAIN)
	$(TEX) $(MAIN)
	$(TEX) $(MAIN)

# Figures are generated by the package CLI from the workspace root.
figures $(FIGURES):
	cd ../.. && $(UV) run jr-hz-relation figures --outdir packages/pre-print

# The test-particle validation figure (test-particle-bias.pdf) comes from an
# expensive, stochastic orbit-integration experiment, not the engine. It is
# committed; regenerate (a few minutes) with:
test-particle:
	$(UV) run python test_particle_bias.py

OUTDIR  = /tmp/jr-hz-relation
TARFILE = $(OUTDIR)/jr-hz-relation-preprint.tar

submission: all
	@mkdir -p $(OUTDIR)
	@COPYFILE_DISABLE=1 tar cf $(TARFILE) $(MAIN).tex $(MAIN).bbl $(MAIN).pdf $(FIGURES)
	@echo "Created $(TARFILE)"

clean:
	rm -f $(MAIN).aux $(MAIN).bbl $(MAIN).blg $(MAIN).log $(MAIN).out
	rm -f $(MAIN).fdb_latexmk $(MAIN).fls $(MAIN).synctex.gz $(MAIN).toc

distclean: clean
	rm -f $(MAIN).pdf $(FIGURES)
